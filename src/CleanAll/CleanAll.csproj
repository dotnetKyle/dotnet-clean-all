<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
		
		<PackAsTool>true</PackAsTool>
		<Authors>dotnetKyle</Authors>
		<Description>A package that removes all bin and obj files that sometimes a 3rd party tool leaves behind after a dotnet clean is ran.</Description>
		<PackageTags>dotnet, clean</PackageTags>
		<PackageReleaseNotes>Initial version, alpha</PackageReleaseNotes>
		<PackageProjectUrl>https://github.com/dotnetKyle/dotnet-clean-all</PackageProjectUrl>
		<RepositoryUrl>https://github.com/dotnetKyle/dotnet-clean-all</RepositoryUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SolutionPersistence" Version="1.0.52" />
    <PackageReference Include="ShellRunner" Version="0.2.10-alpha" />
    <PackageReference Include="MinimalCli" Version="2.0.4.57" />
  </ItemGroup>

	<ItemGroup>
		<None Include="..\..\README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>

</Project>
